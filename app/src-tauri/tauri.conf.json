{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DdShell",
  "version": "0.3.0",
  "identifier": "com.hanyongding.ddshell",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DdShell",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost; media-src 'self' asset: http://asset.localhost data:; object-src 'none'; base-uri 'self'; frame-src 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["$APPDATA/terminal-backgrounds/**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Open-source SSH/SFTP desktop client",
    "longDescription": "DdShell is an open-source cross-platform SSH/SFTP desktop client built with Tauri 2 + React + Rust. It provides terminal management, SFTP file transfer, command snippets, and more.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installerHooks": "nsis-hooks.nsh"
      },
      "wix": {
        "upgradeCode": "1d44d0f1-f4a7-53ec-b373-2aa28614a169",
        "fragmentPaths": ["wix-preserve-install-dir.wxs"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMzRkZCNjU2MDY0MDBGNjQKUldSa0QwQUdWcmIvTTFiWHpXcURTb0h3QTBzWitEenRkbWVJMEVvTGhGVjYxSmdrckJ1VXBQUjAK",
      "endpoints": [
        "https://github.com/MrHan-Yd/DdShell/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
